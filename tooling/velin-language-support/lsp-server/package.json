{
  "name": "@velin/lsp-server",
  "version": "0.1.0",
  "description": "Language Server Protocol server for Velin HTML directives. Powers IntelliSense, F12, semantic tokens, and directive-placement diagnostics for `vln-*` attributes.",
  "keywords": [
    "velin",
    "lsp",
    "language-server",
    "html",
    "directives"
  ],
  "license": "MIT",
  "author": "Timoteo Frascaroli",
  "repository": {
    "type": "git",
    "url": "https://github.com/TFrascaroli/velin",
    "directory": "tooling/velin-language-support/lsp-server"
  },
  "bugs": {
    "url": "https://github.com/TFrascaroli/velin/issues"
  },
  "homepage": "https://github.com/TFrascaroli/velin/tree/main/tooling/velin-language-support/lsp-server#readme",
  "main": "dist/server.js",
  "bin": {
    "velin-lsp": "dist/server.js"
  },
  "files": [
    "dist/server.js",
    "dist/server.js.map",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "typecheck": "tsc -p ./ --noEmit",
    "build": "npm run typecheck && node esbuild.mjs",
    "dev": "node esbuild.mjs --watch",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "typescript": "^5.8.3",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11",
    "vscode-uri": "^3.0.8"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@velin/shared": "*",
    "esbuild": "^0.28.1",
    "vitest": "^3.2.6"
  }
}
